# Bu dosyayı .env olarak kopyala ve doldur
# cp .env.example .env

# Flask
SECRET_KEY=cok-gizli-bir-anahtar-buraya-yaz

# Supabase (Settings → API)
SUPABASE_URL=https://akieehczrcdgsyssjief.supabase.co
SUPABASE_KEY=eyJhbGc...service_role_key_buraya...

# Opsiyonel: python yedek_buluta.py ile proje zip'ini Storage'a yüklemek için bucket adı
# (Dashboard → Storage → Create bucket → Private; varsayılan ad: erp-yedekler)
# SUPABASE_BACKUP_BUCKET=erp-yedekler

# Supabase PostgreSQL (Database → Settings → Connection string)
DB_HOST=db.akieehczrcdgsyssjief.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=SIFREN_BURAYA

# Gemini AI (Müşteriler → Gemini AI Analiz)
# https://aistudio.google.com/apikey adresinden ücretsiz key alabilirsiniz
GEMINI_API_KEY=

# İlan robotu (Selenium ile Sahibinden / Hepsiemlak otomatik yayınlama)
